<?xml version='1.0' encoding='utf-8'?>
<kml xmlns:ns0="http://www.opengis.net/kml/2.2" xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>J2 — Cap a l'Ouest — Galway !</name>
    <ns0:Placemark>
      <ns0:name>Sean's Bar, Athlone</ns0:name>
      <ns0:description>Plus vieux pub d'Irlande (900 ap. J.-C. !). Dejeuner au bord du Shannon, murs en torchis d'epoque.&lt;br/&gt;&lt;br/&gt;&lt;a href="https://www.seansbar.ie/"&gt;Site web&lt;/a&gt; | &lt;a href="https://www.tripadvisor.fr/Attraction_Review-g212091-d1580894-Reviews-Sean_s_Bar-Athlone_County_Westmeath.html"&gt;TripAdvisor&lt;/a&gt; | &lt;a href="https://www.google.com/maps/search/?api=1&amp;query=Sean's+Bar+Athlone+Ireland"&gt;Google Maps&lt;/a&gt;</ns0:description>
      <ns0:address>Sean's Bar, Athlone, Ireland</ns0:address>
    </ns0:Placemark>
    <ns0:Placemark>
      <ns0:name>Burgess Park</ns0:name>
      <ns0:description>Parc au bord du Shannon avec aire de jeux. Les enfants se degourdissent apres la route.&lt;br/&gt;&lt;br/&gt;&lt;a href="https://www.google.com/maps/search/?api=1&amp;query=Burgess+Park+Athlone+Ireland"&gt;Google Maps&lt;/a&gt;</ns0:description>
      <ns0:address>Burgess Park, Athlone, Ireland</ns0:address>
    </ns0:Placemark>
    <ns0:Placemark>
      <ns0:name>Galway Latin Quarter &amp; Shop Street</ns0:name>
      <ns0:description>Coeur vibrant : musiciens de rue, facades colorees, boutiques. Spanish Arch et Long Walk.&lt;br/&gt;&lt;br/&gt;&lt;a href="https://www.tripadvisor.fr/Attraction_Review-g186609-d4909613-Reviews-Galway_s_Latin_Quarter-Galway_County_Galway_Western_Ireland.html"&gt;TripAdvisor&lt;/a&gt; | &lt;a href="https://www.routard.com/fr/guide/europe/irlande/comte-de-galway/galway-gaillimh"&gt;Routard&lt;/a&gt; | &lt;a href="https://www.google.com/maps/search/?api=1&amp;query=Galway+Latin+Quarter+%26+Shop+Street+Galway+Ireland"&gt;Google Maps&lt;/a&gt;</ns0:description>
      <ns0:address>Latin Quarter, Galway, Ireland</ns0:address>
    </ns0:Placemark>
    <ns0:Placemark>
