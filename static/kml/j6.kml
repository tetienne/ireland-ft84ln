<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>J6 — Connemara sauvage &amp; retour Est</name>
    <Placemark>
      <name>Parc National du Connemara</name>
      <description>3 sentiers : Sruffaunboy (1,5 km, tres facile, platelage bois), Lower Diamond Hill (3 km, faisable des 5-6 ans), Upper (3,8 km, sommet 442m). Gratuit. Demonstrations de chiens de berger en saison.&lt;br/&gt;&lt;br/&gt;&lt;a href="https://www.connemaranationalpark.ie/"&gt;Site web&lt;/a&gt; | &lt;a href="https://www.tripadvisor.fr/Attraction_Review-g186609-d546269-Reviews-Connemara_National_Park_Visitor_Centre-Galway_County_Galway_Western_Ireland.html"&gt;TripAdvisor&lt;/a&gt; | &lt;a href="https://www.routard.com/fr/guide/europe/irlande/connemara/letterfrack"&gt;Routard&lt;/a&gt; | &lt;a href="https://www.google.com/maps/search/?api=1&amp;query=Connemara+National+Park+Ireland"&gt;Google Maps&lt;/a&gt;</description>
      <address>Connemara National Park, Letterfrack, Ireland</address>
    </Placemark>
    <Placemark>
      <name>Viking Tours Athlone</name>
      <description>Croisiere en replique de drakkar viking sur le Shannon (75 min). Les enfants peuvent piloter le bateau ! Casques et epees vikings en vente. Prevoir 75 min.&lt;br/&gt;&lt;br/&gt;&lt;a href="https://www.vikingtoursireland.ie/"&gt;Site web&lt;/a&gt; | &lt;a href="https://www.tripadvisor.fr/Attraction_Review-g212091-d1119252-Reviews-Viking_Tours-Athlone_County_Westmeath.html"&gt;TripAdvisor&lt;/a&gt; | &lt;a href="https://www.routard.com/fr/mag/reportage/a/les-lakelands-l-irlande-secrete"&gt;Routard&lt;/a&gt; | &lt;a href="https://www.google.com/maps/search/?api=1&amp;query=Viking+Tours+Athlone+Ireland"&gt;Google Maps&lt;/a&gt;</description>
      <address>Viking Tours, Athlone, Ireland</address>
    </Placemark>
